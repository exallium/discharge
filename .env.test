# Test Environment Configuration
# Used by: npm run test:e2e, npm run test:integration
# Requires: docker compose -f docker-compose.test.yml up -d

NODE_ENV=test
PORT=3000

# Database (test container on port 5433)
DATABASE_URL=postgres://test:testpassword@localhost:5433/ai_bug_fixer_test

# Redis (test container on port 6380)
REDIS_URL=redis://localhost:6380

# Encryption key for settings (test-only, not secure)
DB_ENCRYPTION_KEY=Ph7YsM+Tn+j7RQIi4vUuvwmPblL233ekB6dbJDxEVwA=

# Admin credentials for tests
ADMIN_USERNAME=admin
ADMIN_PASSWORD=testpassword123

# Session secret for cookie-based auth
SESSION_SECRET=test-session-secret-at-least-32-characters-long

# System
WORKER_CONCURRENCY=1
LOG_LEVEL=error
LOG_FORMAT=json

# Placeholder values for plugins (not needed for admin UI tests)
GITHUB_TOKEN=ghp_placeholder_for_e2e_testing
GITHUB_WEBHOOK_SECRET=placeholder-webhook-secret-for-e2e-tests
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
CIRCLECI_TOKEN=
