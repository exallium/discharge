# =============================================================================
# AI Bug Fixer - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# SECURITY: Never commit .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# GitHub Integration (Required for GitHub VCS and Issues Trigger)
# -----------------------------------------------------------------------------
# Create a personal access token at: https://github.com/settings/tokens
# Required scopes:
#   - repo (full repository access) OR public_repo (for public repos only)
#   - read:org (if working with org repositories)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Webhook secret for validating GitHub webhook signatures
# Generate a random string: openssl rand -hex 32
# Must match the secret configured in GitHub webhook settings
GITHUB_WEBHOOK_SECRET=your-random-secret-string-min-20-chars

# -----------------------------------------------------------------------------
# Sentry Integration (Optional - for Sentry error monitoring trigger)
# -----------------------------------------------------------------------------
# Create an auth token at: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: project:read, event:read, org:read
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx

# Your Sentry organization slug (found in Sentry URL)
SENTRY_ORG=your-org-slug

# -----------------------------------------------------------------------------
# CircleCI Integration (Optional - for CircleCI build failure trigger)
# -----------------------------------------------------------------------------
# Create a personal API token at: https://app.circleci.com/settings/user/tokens
CIRCLECI_TOKEN=CCIPAT_xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Anthropic Claude API (Required)
# -----------------------------------------------------------------------------
# Get your API key from: https://console.anthropic.com/settings/keys
# This is used by Claude Code CLI to access Claude models
# Note: Your Claude CLI must be authenticated (run `claude auth` once)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Notifications (Optional)
# -----------------------------------------------------------------------------
# Discord webhook URL for sending notifications about fixes
# Create webhook in Discord: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx

# Slack webhook URL for sending notifications (alternative to Discord)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# -----------------------------------------------------------------------------
# System Configuration
# -----------------------------------------------------------------------------
# Environment mode: development | production | test
NODE_ENV=production

# HTTP server port
PORT=3000

# Number of concurrent worker processes for processing jobs
# Recommendation: 1-2 per CPU core, consider API rate limits
WORKER_CONCURRENCY=2

# Redis connection URL for job queue
# Format: redis://[user][:password@]host[:port][/db-number]
# For production, use redis://:password@host:port
REDIS_URL=redis://localhost:6379

# User for Docker volume mounting (typically your macOS/Linux username)
# This allows Claude Code CLI to access your ~/.claude credentials
USER=yourusername

# Alternative user variable for host system
HOST_USER=yourusername

# -----------------------------------------------------------------------------
# Docker Configuration (For Claude Runner)
# -----------------------------------------------------------------------------
# Docker network name for inter-container communication
DOCKER_NETWORK=claude-agent_internal

# CPU limit for Claude runner containers (in cores)
DOCKER_CPU_LIMIT=2

# Memory limit for Claude runner containers (e.g., 4g, 8g)
DOCKER_MEMORY_LIMIT=4g

# Maximum execution time for Claude jobs (milliseconds)
# Default: 600000 (10 minutes)
CLAUDE_TIMEOUT_MS=600000

# Maximum turns for Claude agent execution
CLAUDE_MAX_TURNS=30

# -----------------------------------------------------------------------------
# Security & Rate Limiting
# -----------------------------------------------------------------------------
# Rate limit for webhook endpoints (requests per minute per IP)
RATE_LIMIT_WEBHOOK=60

# Rate limit for API endpoints (requests per minute per IP)
RATE_LIMIT_API=100

# Enable webhook signature validation (strongly recommended for production)
REQUIRE_WEBHOOK_SIGNATURES=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: error | warn | info | debug
LOG_LEVEL=info

# Log format: json | pretty
LOG_FORMAT=json

# Enable request logging
LOG_REQUESTS=true

# -----------------------------------------------------------------------------
# Optional: Custom Claude CLI Path
# -----------------------------------------------------------------------------
# If Claude Code CLI is not in PATH, specify full path
# CLAUDE_CLI_PATH=/usr/local/bin/claude
