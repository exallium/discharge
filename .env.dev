# Local Development Configuration
# Uses test containers for Postgres and Redis

NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgres://test:testpassword@localhost:5432/ai_bug_fixer

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=test
POSTGRES_PASSWORD=testpassword

# Redis
REDIS_URL=redis://localhost:6379

# Encryption key for settings (dev-only, not secure)
DB_ENCRYPTION_KEY=Ph7YsM+Tn+j7RQIi4vUuvwmPblL233ekB6dbJDxEVwA=

# Session secret for cookie-based auth
SESSION_SECRET=dev-session-secret-at-least-32-characters-long

# Admin - leave empty to use generated password on first run
ADMIN_USERNAME=admin
# ADMIN_PASSWORD=

# System
WORKER_CONCURRENCY=1
LOG_LEVEL=info
LOG_FORMAT=pretty

# Agent Runner
ENABLE_DOCKER_IN_AGENT=true

# GitHub (optional - fill in for full functionality)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Sentry (optional)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=

# CircleCI (optional)
CIRCLECI_TOKEN=

WORKTREE_DIR=/tmp/ai-bug-fixer-workspaces
