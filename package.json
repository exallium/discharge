{
  "name": "discharge",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered bug fixing, powered by Claude",
  "author": "Alex Hart",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/exallium/discharge.git"
  },
  "homepage": "https://github.com/exallium/discharge#readme",
  "bugs": {
    "url": "https://github.com/exallium/discharge/issues"
  },
  "keywords": ["ai", "bug-fixing", "claude", "automation", "github", "sentry", "discharge"],
  "workspaces": [
    "packages/service-sdk",
    "packages/service-locator",
    "packages/services/*",
    "router"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:packages": "npm run build -w @discharge/service-sdk && npm run build -w @discharge/service-locator && npm run build -w @discharge/service-github && npm run build -w @discharge/service-sentry && npm run build -w @discharge/service-circleci && npm run build -w @discharge/service-claude-code",
    "dev": "npm run dev -w router",
    "dev:up": "npm run dev:up -w router",
    "dev:setup": "npm run dev:setup -w router",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test:unit -w router",
    "test:router": "npm run test -w router",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
