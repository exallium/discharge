# Local Development Configuration
# Uses test containers for Postgres and Redis

NODE_ENV=development
PORT=3000

# Database (dev database on test container port 5433)
DATABASE_URL=postgres://test:testpassword@localhost:5433/ai_bug_fixer_dev

# Redis (test container on port 6380)
REDIS_URL=redis://localhost:6380

# Encryption key for settings (dev-only, not secure)
DB_ENCRYPTION_KEY=Ph7YsM+Tn+j7RQIi4vUuvwmPblL233ekB6dbJDxEVwA=

# Session secret for cookie-based auth
SESSION_SECRET=dev-session-secret-at-least-32-characters-long

# Admin - leave empty to use generated password on first run
ADMIN_USERNAME=admin
# ADMIN_PASSWORD=

# System
WORKER_CONCURRENCY=1
LOG_LEVEL=info
LOG_FORMAT=pretty

# GitHub (optional - fill in for full functionality)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Sentry (optional)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=

# CircleCI (optional)
CIRCLECI_TOKEN=
