{
  "name": "ai-bug-fixer-router",
  "version": "1.0.0",
  "description": "Generic webhook router and orchestrator for AI Bug Fixer",
  "scripts": {
    "dev": "dotenv -e .env.dev -- next dev",
    "dev:setup": "docker compose -f ../docker-compose.yml --profile build-only build && echo '✓ Agent runner image built. Run: npm run dev:up'",
    "dev:up": "docker compose -f ../docker-compose.yml up -d postgres redis && dotenv -e .env.dev -- next dev",
    "dev:down": "docker compose -f ../docker-compose.yml down postgres redis",
    "dev:test": "dotenv -e .env.test -- next dev",
    "build": "next build && tsc -p tsconfig.worker.json",
    "start": "next start",
    "worker": "node dist/worker.js",
    "worker:dev": "dotenv -e .env.dev -- ts-node --project tsconfig.worker.json src/worker.ts",
    "test": "jest --testPathIgnorePatterns=integration --testPathIgnorePatterns=e2e",
    "test:unit": "jest --testPathIgnorePatterns=integration --testPathIgnorePatterns=e2e",
    "test:integration": "jest --testPathPattern=integration --runInBand",
    "test:watch": "jest --watch --testPathIgnorePatterns=integration --testPathIgnorePatterns=e2e",
    "test:coverage": "jest --coverage --testPathIgnorePatterns=integration --testPathIgnorePatterns=e2e",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test && npm run test:e2e",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.1.2",
    "@octokit/rest": "^20.0.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.38.0",
    "ioredis": "^5.3.2",
    "iron-session": "^8.0.4",
    "lucide-react": "^0.468.0",
    "next": "^16.1.1",
    "next-themes": "^0.4.4",
    "otpauth": "^9.4.1",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.6.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.57.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.1.1",
    "jest": "^29.7.0",
    "postcss": "^8.4.49",
    "supertest": "^6.3.3",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.19.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
